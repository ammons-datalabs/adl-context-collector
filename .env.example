DATABASE_URL=postgresql://user@localhost:5432/open_brain
OPENAI_API_KEY=sk-...

# Optional: override default domains (comma-separated)
# Defaults: general, project, reference
# BRAIN_DOMAINS=general,project,reference

# Optional: override default capture types (comma-separated)
# Defaults: thought, decision, analysis, note, meeting, insight, plan, reference
# BRAIN_CAPTURE_TYPES=thought,decision,analysis,note,meeting,insight,plan,reference

# Optional: path to a JSON config file for tool descriptions and parameter hints
# See config.example.json for the full overridable surface
# BRAIN_CONFIG=/path/to/my-config.json
